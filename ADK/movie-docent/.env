# ======================================
# movie-docent .env 템플릿
# 사용법:
#   1) 이 파일을 .env로 복사: cp .env.example .env  (Windows: copy .env.example .env)
#   2) GEMINI_API_KEY만 당장 채우면 Phase 0~2 진행 가능
#   3) Supabase 관련 값은 Phase 2 후반에 필요
# ======================================

# ------ 모델 선택 (Phase 1+) ------
# LLM_PROVIDER: gemini | openai | claude | fake
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
TAGGER_PROVIDER=gemma_local

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
EMBEDDING_DIMENSION=768

# ------ API 키 ------
# Gemini (무료 티어 O): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 아래 3개는 당장 필요 없음 (Phase 4 A/B 비교 단계에서 선택)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=

# ------ Supabase (Phase 2 후반부터) ------
# 지금은 비워둬도 앱 실행 OK
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=

# ------ 외부 API ------
# TMDB: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ------ 캐시 ------
# 이 값 튜닝은 eval 돌리면서 조정. 0.92가 대략적 시작점.
CACHE_SIMILARITY_THRESHOLD=0.92

# ------ 검색 ------
RETRIEVER_TOP_K=6
GROUNDING_ENABLED=true

# ------ 로깅 / LangSmith ------
LOG_LEVEL=INFO
# Phase 3부터 디버깅에 매우 유용. 키 발급: https://smith.langchain.com/
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=movie-docent

# ------ 환경 ------
APP_ENV=dev
